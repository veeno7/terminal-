{
  "name": "cortexforge",
  "version": "1.0.0",
  "description": "Modular cognitive architecture for an autonomous AI agent",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && node scripts/copy-skills.cjs",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec 'npm run build && npm start'",
    "copy-skills": "node scripts/copy-skills.cjs",
    "setup": "./scripts/setup.sh",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:rebuild": "docker-compose build --no-cache && docker-compose up -d"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ai-sdk/openai": "^0.0.31",
    "@google/generative-ai": "^0.21.0",
    "@langchain/community": "^0.2.14",
    "@langchain/core": "^0.2.13",
    "@langchain/openai": "^0.1.2",
    "axios": "^1.7.2",
    "better-sqlite3": "^11.0.0",
    "bullmq": "^5.8.3",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "groq-sdk": "^0.3.3",
    "ioredis": "^5.4.1",
    "langchain": "^0.2.5",
    "openai": "^4.51.0",
    "p-queue": "^8.0.1",
    "p-retry": "^6.2.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "ws": "^8.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
