# ============================================================
# CortexForge — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# ─── LLM API Keys ────────────────────────────────────────────
# Groq API key for reflexive/low-latency actions
# Get one at https://console.groq.com
GROQ_API_KEY=

# OpenAI API key for deep deliberation/complex planning
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Server Configuration ───────────────────────────────────
# Port for the API server (default: 3001)
API_PORT=3001

# Port for the core engine (default: 3000)
PORT=3000

# Node environment: development | production
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────
# Path to the SQLite database directory
DATABASE_PATH=./data/db

# Vector database configuration (for memory retrieval)
VECTOR_DB_PATH=./data/vector

# ─── Logging ─────────────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL=info

# ─── Feature Flags ───────────────────────────────────────────
# Enable/disable the idle "breathing" reflection cycle
ENABLE_IDLE_REFLECTION=true

# Maximum number of concurrent tasks
MAX_CONCURRENT_TASKS=5